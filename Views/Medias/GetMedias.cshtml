@model IEnumerable<Models.Media>
@{
    var connectedUser = Models.User.ConnectedUser;
    bool isAdmin = connectedUser != null && connectedUser.IsAdmin;
}


@if (Model.Count() != 0)
{
    foreach (var media in Model)
    {
        var owner = DAL.DB.Users.Get(media.OwnerId);
        bool isOwner = connectedUser != null && media.OwnerId == connectedUser.Id;
        <div class="mediaLayout">
            <a href="/Medias/Details/@media.Id" title="Voir les détails de @media.Title" style="text-decoration:none; width:100% !important">
                <div class="mediaThumbnail"
                     style="        background-image: url('https://img.youtube.com/vi/@media.YoutubeId/mqdefault.jpg'); padding: 6px; display: flex; flex-flow: row-reverse">

                    @if (owner != null)
                    {
                        <div class="UserSmallAvatar transparentBackground" style="background-image: url('@owner.Avatar'); border:0.1px solid white;" title="Ajouté par @owner.Name;"></div>

                    }

                    @if (isOwner || isAdmin)
                    {
                        if (media.Shared)
                        {
                            <div class="UserSmallAvatar transparentBackground" style="background-image: url('/Content/UI-Images/shared.png'); margin-right:6px;" title="partagée"></div>
                        }
                        else
                        {
                            <span class="fa fa-lock"
                                  title="Non partagé"
                                  style="position:absolute; bottom:6px; left:6px; color:white; font-size:1.2em; text-shadow: 1px 1px 3px rgba(0,0,0,0.8);">
                            </span>
                        }
                    }
                </div>
            </a>

            <div class="ellipsis" style="margin-left: 4px; margin-right: 4px; font-size: 0.8em; font-weight: bold">
                @media.Title
            </div>
            <div style="margin-left: 4px; color: gray; font-size: 0.65em">@media.Category <br /> @Helper.When(media.PublishDate) </div>
        </div>
    }
}
else
{
    <h3>Aucun résulat</h3>
}
